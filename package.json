{
  "name": "bmad-studio",
  "version": "0.2.0",
  "description": "Browser-based admin interface for BMAD agentic engineering framework — visualize, configure, and manage your BMAD project",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "bin": {
    "bmad-studio": "./bin/bmad-studio.mjs"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w @bmad-studio/server\" \"npm run dev -w @bmad-studio/client\"",
    "build": "npm run build -w @bmad-studio/shared && npm run build -w @bmad-studio/client && npm run build -w @bmad-studio/server",
    "start": "node packages/server/dist/index.js",
    "test": "vitest run",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.58.2",
    "@types/adm-zip": "^0.5.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "form-data": "^4.0.1",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwhiteside/bmad-studio.git"
  },
  "homepage": "https://github.com/jwhiteside/bmad-studio#readme",
  "bugs": {
    "url": "https://github.com/jwhiteside/bmad-studio/issues"
  },
  "keywords": [
    "bmad",
    "ai-agents",
    "agentic-engineering",
    "workflow",
    "admin",
    "studio",
    "configuration",
    "visualization"
  ],
  "files": [
    "bin/",
    "packages/server/dist/",
    "packages/client/dist/",
    "packages/shared/src/",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "adm-zip": "^0.5.16",
    "chokidar": "^5.0.0",
    "fastify": "^5.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  },
  "author": "Jonathan Whiteside",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
